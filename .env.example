# 复制这个文件为 .env，然后根据你的本地环境填写

# ---- PostgreSQL（和 docker-compose.yml 保持一致）----
POSTGRES_USER=stayalive
POSTGRES_PASSWORD=stayalive
POSTGRES_DB=stayalive
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 后端会用这个完整 URL 连接数据库
DATABASE_URL=postgresql://stayalive:stayalive@localhost:5432/stayalive

# ---- FastAPI ----
# 本地开发不需要改，生产环境记得换成随机长字符串
SECRET_KEY=local-dev-secret-key-change-in-production
